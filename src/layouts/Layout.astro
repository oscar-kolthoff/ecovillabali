---
import Navigation from "@/components/Navigation";
import Footer from "@/components/Footer.astro";
import FloatingWhatsApp from "@/components/FloatingWhatsApp.astro";
import { Toaster } from "@/components/ui/sonner";
import { PROPERTY_ADDRESS } from "@/lib/schema";
import "@/styles/global.css";

const SITE_URL = "https://ecovillabali.com";
const DEFAULT_IMAGE = `${SITE_URL}/images/villa-sungai-hero.webp`;

interface Props {
  title: string;
  description: string;
  /** Absolute image URL for social sharing. Defaults to the Villa Sungai hero. */
  image?: string;
  /** og:type. Use "product" for the two villa listing pages. */
  type?: "website" | "product";
}

const { title, description, image = DEFAULT_IMAGE, type = "website" } = Astro.props;
// Normalise to the no-slash form (matching the sitemap) so canonical and
// og:url never advertise a trailing-slash duplicate, even if one is hit.
const normalisedPath = Astro.url.pathname.replace(/(.)\/+$/, "$1");
const canonicalUrl = new URL(normalisedPath, SITE_URL).toString();
const cspNonce = Astro.locals.cspNonce as string | undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:site_name" content="Eco Villa Bali" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <script type="application/ld+json" is:inline nonce={cspNonce} set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: "Eco Villa Bali",
      url: `${SITE_URL}/`,
      description: "Eco Villa Bali sells two sustainable family villas, Villa Sungai and Villa Kailash, within an 8-minute walk of Green School Bali in Eco Village Sibang.",
      address: PROPERTY_ADDRESS,
      founder: { "@type": "Person", name: "Oscar Kolthoff", url: `${SITE_URL}/about`, sameAs: ["https://www.linkedin.com/in/oscarkolthoff/"], description: "Owner of Eco Villa Bali, a former resident of Eco Village Sibang and former Green School Bali parent." },
    })} />
    <script type="application/ld+json" is:inline nonce={cspNonce} set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "Eco Villa Bali",
      url: `${SITE_URL}/`,
    })} />

    <!-- Page-specific structured data (FAQPage, Product, BreadcrumbList) -->
    <slot name="head" />

    <!-- Analytics (gtag.js + Microsoft Clarity): the queue stubs are wired up
         immediately so early gtag()/clarity() calls don't drop, but the heavy
         scripts (~72KB gtag, ~25KB Clarity) are only fetched on first user
         interaction (or after 5s for users who never interact), keeping both
         off the critical path for LCP/INP. -->
    <script is:inline nonce={cspNonce}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XW73MEVXWG');
      window.clarity = window.clarity || function(){(window.clarity.q=window.clarity.q||[]).push(arguments)};

      function loadAnalytics() {
        if (window.__analyticsLoaded) return;
        window.__analyticsLoaded = true;
        var g = document.createElement('script');
        g.async = true;
        g.src = 'https://www.googletagmanager.com/gtag/js?id=G-XW73MEVXWG';
        document.head.appendChild(g);
        var c = document.createElement('script');
        c.async = true;
        c.src = 'https://www.clarity.ms/tag/x73tmcq99l';
        document.head.appendChild(c);
      }
      ['scroll', 'mousemove', 'touchstart', 'keydown'].forEach(function (evt) {
        window.addEventListener(evt, loadAnalytics, { once: true, passive: true });
      });
      setTimeout(loadAnalytics, 5000);
    </script>
  </head>

  <body class="min-h-screen flex flex-col bg-background font-sans text-foreground selection:bg-primary/20">
    <Navigation currentPath={Astro.url.pathname} client:load />

    <main class="flex-grow">
      <slot />
    </main>

    <Footer />
    <FloatingWhatsApp />
    <Toaster client:load />
  </body>
</html>
