---
import Layout from "@/layouts/Layout.astro";
import HeroLanding from "@/components/HeroLanding";
import ChooseVilla from "@/components/ChooseVilla";
import GreenSchool from "@/components/GreenSchool";
import HomeGallery from "@/components/HomeGallery";
import LifestyleTeaser from "@/components/LifestyleTeaser";
import StillDeciding from "@/components/StillDeciding";
import HomeInquiryCTA from "@/components/HomeInquiryCTA";

const title = "Eco Villas for Sale Near Green School Bali";
const description =
  "Discover two unique eco villas within walking distance of Green School Bali. Sustainable homes designed for families seeking nature, community and exceptional living.";
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    {/* No <link rel="preload"> for the hero image: it can't reliably match
        the <img>'s srcset choice (it fetched the full-size image regardless
        of viewport), causing a duplicate download on mobile. fetchpriority
        "high" on the <img> itself is enough for the preload scanner to find
        the correct (responsive) candidate early. */}
  </Fragment>

  <HeroLanding client:load />
  {/* Property choice comes first, right after the hero, on every device.
      client:load (not client:visible): this section sits close enough to
      the hero that it can already be in the viewport before Astro's own
      visibility observer fires, which raced with framer-motion's
      whileInView and left the cards stuck at opacity:0 in production. */}
  <ChooseVilla client:load />
  {/* Why the location matters for both villas */}
  <GreenSchool client:visible />
  {/* A mixed look at both homes */}
  <HomeGallery client:visible />
  <LifestyleTeaser client:visible />
  <StillDeciding client:visible />
  <HomeInquiryCTA client:visible />
</Layout>
