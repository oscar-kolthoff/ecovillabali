---
import Layout from "@/layouts/Layout.astro";
import Contact from "@/components/Contact";
import MeetTheOwners from "@/components/MeetTheOwners";
import { buildBreadcrumbSchema } from "@/lib/schema";

const title = "Inquire Now: Villa Sungai & Villa Kailash";
const description =
  "Request availability, more information, or schedule a viewing for Villa Sungai or Villa Kailash, two eco villas near Green School Bali.";
const breadcrumbSchema = buildBreadcrumbSchema("Inquire Now", "/inquire-now");
const cspNonce = Astro.locals.cspNonce;
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline nonce={cspNonce} set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="pt-8">
    <Contact
      image={{ src: "/images/inquire-jungle-landscape.webp", alt: "Jungle landscape near Eco Village Sibang" }}
      asH1
      client:load
    />
    <MeetTheOwners client:visible />
  </div>
</Layout>
