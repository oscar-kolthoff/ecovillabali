---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero";
import VillaDetails from "@/components/VillaDetails";
import GalleryKailash from "@/components/GalleryKailash";
import VillaHighlights, { villaHighlightsData } from "@/components/VillaHighlights";
import Contact from "@/components/Contact";
import MeetTheOwners from "@/components/MeetTheOwners";
import { buildBreadcrumbSchema, buildFaqSchema, buildResidenceSchema } from "@/lib/schema";

const title = "Villa Kailash: Spacious Eco Villa Near Green School Bali";
const description =
  "Villa Kailash is a spacious 3/4-bedroom eco villa in Sibang with a large natural pool and village views, just an 8-minute walk from Green School Bali.";
const image = "https://ecovillabali.com/images/villa-kailash-hero.webp";

const productSchema = buildResidenceSchema({
  name: "Villa Kailash",
  description:
    "Spacious 3-bedroom eco villa in Eco Village Sibang with a large natural pool, yoga studio, and 950 sqm of land, an 8-minute walk from Green School Bali.",
  image,
  path: "/villa-kailash",
  numberOfBedrooms: 3,
  landAreaSqm: 950,
  amenities: [
    "Large natural pool",
    "Dedicated yoga studio",
    "Dedicated home office",
    "Game and cinema room",
    "Open living areas for hosting",
    "Sustainable construction (mud, teak, bamboo, grass)",
  ],
});
const breadcrumbSchema = buildBreadcrumbSchema("Villa Kailash", "/villa-kailash");
const faqSchema = buildFaqSchema(villaHighlightsData.kailash.faqs);
const cspNonce = Astro.locals.cspNonce;
---

<Layout title={title} description={description} image={image} type="product">
  <Fragment slot="head">
    {/* No <link rel="preload">: it can't reliably match the <img>'s srcset
        choice, causing a duplicate download on mobile. fetchpriority="high"
        on the <img> itself is enough. */}
    <script type="application/ld+json" is:inline nonce={cspNonce} set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" is:inline nonce={cspNonce} set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" is:inline nonce={cspNonce} set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Hero villa="kailash" client:load />
  <VillaDetails villa="kailash" client:visible />
  <GalleryKailash client:visible />
  <VillaHighlights villa="kailash" client:visible />
  <Contact villa="kailash" client:visible />
  <MeetTheOwners client:visible />
</Layout>
