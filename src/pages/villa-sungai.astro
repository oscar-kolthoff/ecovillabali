---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero";
import VillaDetails from "@/components/VillaDetails";
import Gallery from "@/components/Gallery";
import VillaHighlights, { villaHighlightsData } from "@/components/VillaHighlights";
import Contact from "@/components/Contact";
import MeetTheOwners from "@/components/MeetTheOwners";
import { buildBreadcrumbSchema, buildFaqSchema } from "@/lib/schema";

const title = "Villa Sungai: Eco Family Villa Near Green School Bali";
const description =
  "Villa Sungai is a sustainable 3-bedroom eco family home in Sibang, an 8-minute walk from Green School Bali, with a natural pool and riverside setting.";
const image = "https://ecovillabali.com/images/villa-sungai-hero.webp";

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "Villa Sungai",
  description:
    "Sustainable 3-bedroom eco family villa in Eco Village Sibang, an 8-minute walk from Green School Bali, with a natural pool and riverside setting.",
  image,
  brand: { "@type": "Organization", name: "Eco Villa Bali" },
  category: "Eco family villa for sale",
};
const breadcrumbSchema = buildBreadcrumbSchema("Villa Sungai", "/villa-sungai");
const faqSchema = buildFaqSchema(villaHighlightsData.sungai.faqs);
const cspNonce = Astro.locals.cspNonce;
---

<Layout title={title} description={description} image={image} type="product">
  <Fragment slot="head">
    {/* No <link rel="preload">: it can't reliably match the <img>'s srcset
        choice, causing a duplicate download on mobile. fetchpriority="high"
        on the <img> itself is enough. */}
    <script type="application/ld+json" is:inline nonce={cspNonce} set:html={JSON.stringify(productSchema)} />
    <script type="application/ld+json" is:inline nonce={cspNonce} set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" is:inline nonce={cspNonce} set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <Hero villa="sungai" client:load />
  <VillaDetails villa="sungai" client:visible />
  <Gallery client:visible />
  <VillaHighlights villa="sungai" client:visible />
  <Contact villa="sungai" client:visible />
  <MeetTheOwners client:visible />
</Layout>
